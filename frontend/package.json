{
  "name": "library-demo-front",
  "private": true,
  "version": "0.0.1",
  "author": "Alessandro G. Magnasco",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build src",
    "prod": "vite serve src",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "e2e": "cypress open",
    "test:unit": "vitest --testNamePattern UNIT",
    "test:watch": "vitest watch --testNamePattern UNIT",
    "test:integration": "vitest --testNamePattern INTEGRATION",
    "test:coverage": "vitest run --coverage",
    "test:cypress": "cypress open",
    "test:e2e": "cypress open"
  },
  "dependencies": {
    "@eslint/js": "^9.7.0",
    "axios": "^1.7.8",
    "easy-peasy": "^6.0.5",
    "i18next": "^23.7.11",
    "i18next-browser-languagedetector": "^7.2.0",
    "react": "^18.0",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^7.13.2",
    "styled-components": "^6.1.11",
    "typescript-eslint": "^7.17.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.14.11",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.3.0",
    "@types/react-i18next": "^7.8.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-istanbul": "^3.0.5",
    "ansicolor": "^2.0.3",
    "globals": "^15.9.0",
    "typescript": "^5.5.3",
    "vite": "^6.2.3",
    "vitest": "^3.0.5"
  }
}
